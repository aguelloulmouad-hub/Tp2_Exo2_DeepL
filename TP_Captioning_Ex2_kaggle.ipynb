  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Q6 : Encodeur spatial (retourne la feature map 7×7 = 49 pixels) ────────\n",
    "class SpatialImageEncoder(nn.Module):\n",
    "    \"\"\"ImageEncoder modifié retournant la feature map spatiale (B, 49, 2048).\n",
    "    Permet à l'attention d'accéder à chaque région spatiale de l'image.\n",
    "    \"\"\"\n",
    "    def __init__(self, encoded_image_size=7, fine_tune=False):\n",
    "        super().__init__()\n",
    "        resnet   = resnet50(weights=ResNet50_Weights.IMAGENET1K_V2)\n",
    "        modules  = list(resnet.children())[:-2]       # jusqu'à layer4, sortie (B,2048,H,W)\n",
    "        self.resnet        = nn.Sequential(*modules)\n",
    "        self.adaptive_pool = nn.AdaptiveAvgPool2d((encoded_image_size, encoded_image_size))\n",
    "        self.encoded_size  = encoded_image_size\n",
    "\n",
    "        # Geler l'encodeur sauf les 2 derniers blocs\n",
    "        for param in self.resnet[:6].parameters():\n",
    "            param.requires_grad = fine_tune\n",
    "        for param in self.resnet[6:].parameters():\n",
    "            param.requires_grad = True\n",
    "\n",
    "    def forward(self, images):\n",
    "        feat = self.resnet(images)                    # (B, 2048, H', W')\n",
    "        feat = self.adaptive_pool(feat)               # (B, 2048, enc_size, enc_size)\n",
    "        B, C, H, W = feat.shape\n",
    "        feat = feat.permute(0, 2, 3, 1)              # (B, H, W, C)\n",
    "        feat = feat.view(B, H * W, C)                # (B, num_pixels, 2048)\n",
    "        return feat\n",
    "\n",
    "\n",
    "# ── Mécanisme d'attention Bahdanau ────────────────────────────────────────\n",
    "class BahdanauAttention(nn.Module):\n",
    "    \"\"\"Attention additive (Bahdanau) sur les features spatiaux du CNN.\"\"\"\n",
    "    def __init__(self, encoder_dim, decoder_dim, attention_dim):\n",
    "        super().__init__()\n",
    "        self.enc_att  = nn.Linear(encoder_dim, attention_dim)\n",
    "        self.dec_att  = nn.Linear(decoder_dim, attention_dim)\n",
    "        self.full_att = nn.Linear(attention_dim, 1)\n",
    "\n",
    "    def forward(self, encoder_out, decoder_hidden):\n",
    "        \"\"\"\n",
    "        encoder_out    : (B, num_pixels, encoder_dim)  — 49 régions, 2048 dim\n",
    "        decoder_hidden : (B, decoder_dim)              — état caché du LSTM\n",
    "        \"\"\"\n",
    "        att1   = self.enc_att(encoder_out)                    # (B, 49, att_dim)\n",
    "        att2   = self.dec_att(decoder_hidden).unsqueeze(1)    # (B,  1, att_dim)\n",
    "        energy = self.full_att(torch.tanh(att1 + att2))       # (B, 49, 1)\n",
    "        alpha  = F.softmax(energy.squeeze(2), dim=1)          # (B, 49)  — poids d'attention\n",
    "        context = (alpha.unsqueeze(2) * encoder_out).sum(dim=1)  # (B, enc_dim)\n",
    "        return context, alpha\n",
    "\n",
    "\n",
    "# ── Décodeur avec attention ────────────────────────────────────────────────\n",
    "class AttentionDecoder(nn.Module):\n",
    "    \"\"\"Décodeur LSTM avec mécanisme d'attention Bahdanau.\n",
    "    Utilise un LSTMCell (pas de LSTM) pour itérer manuellement sur le temps.\n",
    "    \"\"\"\n",
    "    def __init__(self, embed_size, hidden_size, vocab_size,\n",
    "                 encoder_dim=2048, attention_dim=256, dropout=0.5):\n",
    "        super().__init__()\n",
    "        self.attention = BahdanauAttention(encoder_dim, hidden_size, attention_dim)\n",
    "        self.embed     = nn.Embedding(vocab_size, embed_size, padding_idx=0)\n",
    "        self.lstm_cell = nn.LSTMCell(embed_size + encoder_dim, hidden_size)\n",
    "        self.fc        = nn.Linear(hidden_size, vocab_size)\n",
    "        self.init_h    = nn.Linear(encoder_dim, hidden_size)\n",
    "        self.init_c    = nn.Linear(encoder_dim, hidden_size)\n",
    "        self.dropout   = nn.Dropout(dropout)\n",
    "        self.hidden_size = hidden_size\n",
    "\n",
    "    def init_hidden_state(self, encoder_out):\n",
    "        \"\"\"Initialise h et c à partir de la moyenne des features encodeur.\"\"\"\n",
    "        mean_enc = encoder_out.mean(dim=1)          # (B, encoder_dim)\n",
    "        h = torch.tanh(self.init_h(mean_enc))       # (B, hidden_size)\n",
    "        c = torch.tanh(self.init_c(mean_enc))       # (B, hidden_size)\n",
    "        return h, c\n",
    "\n",
    "    def forward(self, encoder_out, captions, lengths):\n",
    "        \"\"\"\n",
    "        encoder_out : (B, 49, 2048)     — feature map spatiale\n",
    "        captions    : (B, max_len)      — séquences numérisées\n",
    "        lengths     : (B,)              — longueurs réelles\n",
    "        \"\"\"\n",
    "        B       = encoder_out.size(0)\n",
    "        h, c    = self.init_hidden_state(encoder_out)   # (B, H), (B, H)\n",
    "        # Embeddings des captions (sans le dernier token <EOS>)\n",
    "        embeddings = self.dropout(self.embed(captions[:, :-1]))  # (B, T-1, E)\n",
    "        max_t      = embeddings.size(1)\n",
    "\n",
    "        predictions = torch.zeros(B, max_t, self.fc.out_features,\n",
    "                                  device=encoder_out.device)\n",
    "        alphas      = torch.zeros(B, max_t, encoder_out.size(1),\n",
    "                                  device=encoder_out.device)\n",
    "\n",
    "        for t in range(max_t):\n",
    "            # Masque : seuls les exemples dont la séquence n'est pas finie\n",
    "            batch_size_t  = (lengths > t + 1).sum().item()\n",
    "            if batch_size_t == 0:\n",
    "                break\n",
    "            context, alpha = self.attention(\n",
    "                encoder_out[:batch_size_t], h[:batch_size_t]\n",
    "            )\n",
    "            lstm_in = torch.cat(\n",
    "                [embeddings[:batch_size_t, t, :], context], dim=1\n",
    "            )  # (batch_size_t, E + enc_dim)\n",
    "            h_new, c_new = self.lstm_cell(\n",
    "                lstm_in, (h[:batch_size_t], c[:batch_size_t])\n",
    "            )\n",
    "            h = h.clone(); c = c.clone()\n",
    "            h[:batch_size_t] = h_new\n",
    "            c[:batch_size_t] = c_new\n",
    "\n",
    "            predictions[:batch_size_t, t] = self.fc(self.dropout(h[:batch_size_t]))\n",
    "            alphas[:batch_size_t, t]      = alpha\n",
    "\n",
    "        return predictions, alphas\n",
    "\n",
    "\n",
    "# ── Instanciation des modèles avec attention ──────────────────────────────\n",
    "ENCODER_DIM   = 2048\n",
    "ATTENTION_DIM = 256\n",
    "\n",
    "enc_att = SpatialImageEncoder(encoded_image_size=7, fine_tune=False).to(device)\n",
    "dec_att = AttentionDecoder(\n",
    "    embed_size=EMBED_SIZE,\n",
    "    hidden_size=HIDDEN_SIZE,\n",
    "    vocab_size=VOCAB_SIZE,\n",
    "    encoder_dim=ENCODER_DIM,\n",
    "    attention_dim=ATTENTION_DIM,\n",
    "    dropout=DROPOUT\n",
    ").to(device)\n",
    "\n",
    "# Multi-GPU\n",
    "enc_att_parallel = nn.DataParallel(enc_att) if num_gpus > 1 else enc_att\n",
    "\n",
    "# Vérification des dimensions\n",
    "enc_att.eval(); dec_att.eval()\n",
    "with torch.no_grad():\n",
    "    x_t   = torch.randn(2, 3, IMG_SIZE, IMG_SIZE).to(device)\n",
    "    sp_f  = enc_att(x_t)                        # (2, 49, 2048)\n",
    "    cap_t = torch.randint(4, VOCAB_SIZE, (2, MAX_LEN)).to(device)\n",
    "    len_t = torch.tensor([MAX_LEN, MAX_LEN - 5])\n",
    "    preds, alphas_t = dec_att(sp_f, cap_t, len_t)\n",
    "print(\"📐 Vérification dimensions — Modèle avec Attention :\")\n",
    "print(f\"   Sortie encodeur spatial : {list(sp_f.shape)}  → (B, 49, 2048)\")\n",
    "print(f\"   Sortie predictions      : {list(preds.shape)} → (B, T, vocab_size)\")\n",
    "print(f\"   Sortie alphas           : {list(alphas_t.shape)} → (B, T, num_pixels=49)\")\n",
    "print(f\"   Paramètres encodeur att : {sum(p.numel() for p in enc_att.parameters()):,}\")\n",
    "print(f\"   Paramètres décodeur att : {sum(p.numel() for p in dec_att.parameters()):,}\")\n",
    "enc_att.train(); dec_att.train()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Fonctions d'entraînement pour le modèle avec attention ────────────────\n",
    "def train_epoch_att(enc, dec, loader, criterion, opt_enc, opt_dec, device):\n",
    "    enc.train(); dec.train()\n",
    "    total_loss = 0.0\n",
    "    for imgs, caps, lengths, _ in tqdm(loader, desc='Train-ATT', leave=False):\n",
    "        imgs = imgs.to(device, non_blocking=True)\n",
    "        caps = caps.to(device, non_blocking=True)\n",
    "\n",
    "        enc_out    = enc(imgs)                          # (B, 49, 2048)\n",
    "        preds, _   = dec(enc_out, caps, lengths)        # (B, T, V)\n",
    "\n",
    "        targets = caps[:, 1:]                           # (B, T)\n",
    "        T = min(preds.size(1), targets.size(1))\n",
    "        loss = criterion(\n",
    "            preds[:, :T].reshape(-1, VOCAB_SIZE),\n",
    "            targets[:, :T].reshape(-1)\n",
    "        )\n",
    "        opt_enc.zero_grad(); opt_dec.zero_grad()\n",
    "        loss.backward()\n",
    "        nn.utils.clip_grad_norm_(dec.parameters(), max_norm=5.0)\n",
    "        nn.utils.clip_grad_norm_(\n",
    "            filter(lambda p: p.requires_grad, enc.parameters()), max_norm=5.0\n",
    "        )\n",
    "        opt_enc.step(); opt_dec.step()\n",
    "        total_loss += loss.item()\n",
    "    return total_loss / len(loader)\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def eval_epoch_att(enc, dec, loader, criterion, device):\n",
    "    enc.eval(); dec.eval()\n",
    "    total_loss = 0.0\n",
    "    for imgs, caps, lengths, _ in tqdm(loader, desc='Val-ATT  ', leave=False):\n",
    "        imgs = imgs.to(device, non_blocking=True)\n",
    "        caps = caps.to(device, non_blocking=True)\n",
    "        enc_out  = enc(imgs)\n",
    "        preds, _ = dec(enc_out, caps, lengths)\n",
    "        targets  = caps[:, 1:]\n",
    "        T = min(preds.size(1), targets.size(1))\n",
    "        loss = criterion(\n",
    "            preds[:, :T].reshape(-1, VOCAB_SIZE),\n",
    "            targets[:, :T].reshape(-1)\n",
    "        )\n",
    "        total_loss += loss.item()\n",
    "    return total_loss / len(loader)\n",
    "\n",
    "\n",
    "# ── Optimiseurs pour le modèle avec attention ─────────────────────────────\n",
    "opt_enc_att = torch.optim.Adam(\n",
    "    filter(lambda p: p.requires_grad, enc_att.parameters()),\n",
    "    lr=1e-4, weight_decay=1e-4\n",
    ")\n",
    "opt_dec_att = torch.optim.Adam(dec_att.parameters(), lr=LR, weight_decay=1e-4)\n",
    "scheduler_enc_att = torch.optim.lr_scheduler.ReduceLROnPlateau(opt_enc_att, patience=3, factor=0.5)\n",
    "scheduler_dec_att = torch.optim.lr_scheduler.ReduceLROnPlateau(opt_dec_att, patience=3, factor=0.5)\n",
    "\n",
    "print(\"✅ Optimiseurs et schedulers initialisés pour le modèle avec attention.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Boucle d'entraînement — Modèle avec Attention ─────────────────────────\n",
    "history_att  = {'train_loss': [], 'val_loss': [], 'train_ppl': [], 'val_ppl': [], 'epoch_time': []}\n",
    "best_val_att = float('inf')\n",
    "patience_att = 0\n",
    "\n",
    "print(f\"\\n🚀 Entraînement CNN-LSTM + Attention ({EPOCHS_ATT} epochs)...\\n\")\n",
    "t0_att = time.time()\n",
    "\n",
    "for epoch in range(1, EPOCHS_ATT + 1):\n",
    "    t0 = time.time()\n",
    "    train_loss = train_epoch_att(enc_att_parallel, dec_att, loader_train,\n",
    "                                  criterion, opt_enc_att, opt_dec_att, device)\n",
    "    val_loss   = eval_epoch_att(enc_att_parallel, dec_att, loader_val,\n",
    "                                 criterion, device)\n",
    "    train_ppl = np.exp(train_loss)\n",
    "    val_ppl   = np.exp(val_loss)\n",
    "\n",
    "    history_att['train_loss'].append(train_loss)\n",
    "    history_att['val_loss'].append(val_loss)\n",
    "    history_att['train_ppl'].append(train_ppl)\n",
    "    history_att['val_ppl'].append(val_ppl)\n",
    "    history_att['epoch_time'].append(time.time() - t0)\n",
    "\n",
    "    scheduler_enc_att.step(val_loss)\n",
    "    scheduler_dec_att.step(val_loss)\n",
    "\n",
    "    elapsed = history_att['epoch_time'][-1]\n",
    "    print(f\"Epoch {epoch:02d}/{EPOCHS_ATT} | \"\n",
    "          f\"Train: {train_loss:.4f} (PPL={train_ppl:.1f}) | \"\n",
    "          f\"Val: {val_loss:.4f} (PPL={val_ppl:.1f}) | ⏱ {elapsed:.0f}s\")\n",
    "\n",
    "    if val_loss < best_val_att:\n",
    "        best_val_att = val_loss\n",
