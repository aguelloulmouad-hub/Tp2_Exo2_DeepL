   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Boucle d'entraînement CNN-LSTM ────────────────────────────────────────\n",
    "history_basic = {'train_loss': [], 'val_loss': [], 'train_ppl': [], 'val_ppl': [], 'epoch_time': []}\n",
    "best_val_loss = float('inf')\n",
    "patience_count = 0\n",
    "PATIENCE_STOP  = 5\n",
    "\n",
    "print(f\"\\n🚀 Début de l'entraînement CNN-LSTM ({EPOCHS_BASIC} epochs)...\\n\")\n",
    "t0_total = time.time()\n",
    "\n",
    "for epoch in range(1, EPOCHS_BASIC + 1):\n",
    "    t0 = time.time()\n",
    "\n",
    "    train_loss = train_epoch(enc_parallel, decoder, loader_train,\n",
    "                              criterion, opt_enc, opt_dec, device)\n",
    "    val_loss   = eval_epoch(enc_parallel, decoder, loader_val,\n",
    "                             criterion, device)\n",
    "\n",
    "    train_ppl = np.exp(train_loss)\n",
    "    val_ppl   = np.exp(val_loss)\n",
    "\n",
    "    history_basic['train_loss'].append(train_loss)\n",
    "    history_basic['val_loss'].append(val_loss)\n",
    "    history_basic['train_ppl'].append(train_ppl)\n",
    "    history_basic['val_ppl'].append(val_ppl)\n",
    "    history_basic['epoch_time'].append(time.time() - t0)\n",
    "\n",
    "    scheduler_enc.step(val_loss)\n",
    "    scheduler_dec.step(val_loss)\n",
    "\n",
    "    elapsed = history_basic['epoch_time'][-1]\n",
    "    print(f\"Epoch {epoch:02d}/{EPOCHS_BASIC} | \"\n",
    "          f\"Train Loss: {train_loss:.4f} (PPL={train_ppl:.1f}) | \"\n",
    "          f\"Val Loss: {val_loss:.4f} (PPL={val_ppl:.1f}) | \"\n",
    "          f\"⏱ {elapsed:.0f}s\")\n",
    "\n",
    "    # Sauvegarde du meilleur modèle\n",
    "    if val_loss < best_val_loss:\n",
    "        best_val_loss = val_loss\n",
    "        torch.save({\n",
    "            'encoder': encoder.state_dict(),\n",
    "            'decoder': decoder.state_dict(),\n",
    "            'vocab'  : vocab\n",
    "        }, 'best_captioning_basic.pth')\n",
    "        patience_count = 0\n",
    "        print(f\"   ✅ Nouveau meilleur modèle sauvegardé (val_loss={val_loss:.4f})\")\n",
    "    else:\n",
    "        patience_count += 1\n",
    "        if patience_count >= PATIENCE_STOP:\n",
    "            print(f\"   ⛔ Early stopping déclenché après {epoch} epochs (patience={PATIENCE_STOP}).\")\n",
    "            break\n",
    "\n",
    "total_time_basic = time.time() - t0_total\n",
    "print(f\"\\n⏱ Entraînement total : {total_time_basic/60:.1f} min\")\n",
    "print(f\"Meilleure val_loss : {best_val_loss:.4f} | PPL = {np.exp(best_val_loss):.1f}\")"
   ]
