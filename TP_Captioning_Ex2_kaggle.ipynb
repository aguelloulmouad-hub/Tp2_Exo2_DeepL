    "### Q1 — Vocabulaire : construction, top-20 mots, distribution des longueurs"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Classe Vocabulary ─────────────────────────────────────────────────────\n",
    "class Vocabulary:\n",
    "    \"\"\"Vocabulaire token → index et index → token.\"\"\"\n",
    "    def __init__(self, freq_threshold=5):\n",
    "        self.freq_threshold = freq_threshold\n",
    "        # Tokens spéciaux\n",
    "        self.itos = {0: '<PAD>', 1: '<SOS>', 2: '<EOS>', 3: '<UNK>'}\n",
    "        self.stoi = {v: k for k, v in self.itos.items()}\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.itos)\n",
    "\n",
    "    @staticmethod\n",
    "    def tokenize(text):\n",
    "        return re.findall(r\"\\w+\", text.lower())\n",
    "\n",
    "    def build(self, captions_list):\n",
    "        \"\"\"captions_list : liste de listes de captions (une liste par image).\"\"\"\n",
    "        counter = Counter()\n",
    "        for caps in captions_list:\n",
    "            for cap in caps:\n",
    "                counter.update(self.tokenize(cap))\n",
    "        idx = 4\n",
    "        for word, freq in counter.most_common():\n",
    "            if freq >= self.freq_threshold:\n",
    "                self.stoi[word] = idx\n",
    "                self.itos[idx]  = word\n",
    "                idx += 1\n",
    "        print(f'✅ Taille du vocabulaire : {len(self.itos)} tokens')\n",
    "        return counter\n",
    "\n",
    "    def numericalize(self, caption, max_len=50):\n",
    "        tokens = [self.stoi.get(w, self.stoi['<UNK>']) for w in self.tokenize(caption)]\n",
    "        seq    = [self.stoi['<SOS>']] + tokens[:max_len - 2] + [self.stoi['<EOS>']]\n",
    "        seq   += [self.stoi['<PAD>']] * (max_len - len(seq))  # padding\n",
    "        return seq\n",
    "\n",
    "    def decode(self, indices):\n",
    "        \"\"\"Convertit une liste d'indices en phrase lisible.\"\"\"\n",
    "        words = []\n",
    "        for idx in indices:\n",
    "            w = self.itos.get(idx, '<UNK>')\n",
    "            if w in ('<EOS>', '<PAD>'):\n",
    "                break\n",
    "            if w not in ('<SOS>', '<PAD>'):\n",
    "                words.append(w)\n",
    "        return ' '.join(words)\n",
    "\n",
    "\n",
    "# ── Construction du vocabulaire sur les captions train ────────────────────\n",
    "# Grouper les captions par image_id\n",
    "from collections import defaultdict\n",
    "train_img_captions = defaultdict(list)\n",
    "for ann in train_anns:\n",
    "    train_img_captions[ann['image_id']].append(ann['caption'])\n",
    "\n",
    "vocab   = Vocabulary(freq_threshold=FREQ_THRESH)\n",
    "counter = vocab.build(list(train_img_captions.values()))\n",
    "\n",
    "# ── Top-20 mots les plus fréquents ────────────────────────────────────────\n",
    "top20 = counter.most_common(20)\n",
    "print(\"\\n📊 Top-20 mots les plus fréquents :\")\n",
    "for rank, (word, freq) in enumerate(top20, 1):\n",
    "    print(f\"  {rank:2d}. {word:<15s} → {freq:,}\")"
   ]
