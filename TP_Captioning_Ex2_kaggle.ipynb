    "# ── Q8 : Calcul des scores BLEU sur le modèle avec attention ─────────────\n",
    "print(\"📊 Calcul des scores BLEU — Modèle avec attention (validation complète)...\")\n",
    "\n",
    "# Génération greedy via le modèle avec attention\n",
    "@torch.no_grad()\n",
    "def generate_att_greedy(enc, dec, image_tensor, vocab, max_len=50, device='cpu'):\n",
    "    words_and_alphas, _ = generate_with_attention(enc, dec, image_tensor, vocab, max_len, device)\n",
    "    return ' '.join([w for w, _ in words_and_alphas])\n",
