   "source": [
    "# ── Classe Dataset COCO Caption ───────────────────────────────────────────\n",
    "class COCOCaptionDataset(Dataset):\n",
    "    def __init__(self, annotations, images_info, img_dir,\n",
    "                 vocab, split='train', img_size=224, max_len=50):\n",
    "        self.annotations = annotations\n",
    "        self.images_info = images_info\n",
    "        self.img_dir     = img_dir\n",
    "        self.vocab       = vocab\n",
    "        self.max_len     = max_len\n",
    "\n",
    "        aug = split == 'train'\n",
    "        tf  = [transforms.Resize((img_size, img_size))]\n",
    "        if aug:\n",
    "            tf += [transforms.RandomHorizontalFlip()]\n",
    "        tf += [\n",
    "            transforms.ToTensor(),\n",
    "            transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])\n",
    "        ]\n",
    "        self.transform = transforms.Compose(tf)\n",
    "\n",
    "        # Filtrer les annotations dont l'image existe sur disque\n",
    "        self.data = []\n",
    "        missing   = 0\n",
    "        for ann in annotations:\n",
    "            img_id   = ann['image_id']\n",
    "            img_info = images_info.get(img_id)\n",
    "            if img_info is None:\n",
    "                missing += 1; continue\n",
    "            img_path = os.path.join(img_dir, img_info['file_name'])\n",
    "            if not os.path.exists(img_path):\n",
    "                missing += 1; continue\n",
    "            self.data.append({\n",
    "                'img_path': img_path,\n",
    "                'caption' : ann['caption'],\n",
    "                'image_id': img_id,\n",
    "                'ann_id'  : ann['id']\n",
    "            })\n",
    "        if missing:\n",
    "            print(f\"⚠️  {missing} annotations ignorées (image manquante sur disque).\")\n",
    "        print(f\"Dataset [{split}] : {len(self.data)} exemples valides.\")\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.data)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        item    = self.data[idx]\n",
    "        img     = Image.open(item['img_path']).convert('RGB')\n",
    "        img     = self.transform(img)\n",
    "        caption = torch.tensor(\n",
    "            self.vocab.numericalize(item['caption'], self.max_len),\n",
    "            dtype=torch.long\n",
    "        )\n",
    "        return img, caption, item['image_id']\n",
    "\n",
    "\n",
    "# ── collate_fn : tri par longueur décroissante (requis pour pack_padded_sequence) ──\n",
    "def collate_fn(batch):\n",
    "    \"\"\"Trie les séquences par longueur décroissante.\"\"\"\n",
    "    imgs, caps, img_ids = zip(*batch)\n",
    "    imgs    = torch.stack(imgs, 0)\n",
    "    caps    = torch.stack(caps, 0)\n",
    "    # Longueurs réelles (sans padding)\n",
    "    lengths = (caps != 0).sum(dim=1)\n",
    "    # Tri décroissant\n",
    "    lengths, sort_idx = lengths.sort(descending=True)\n",
    "    imgs    = imgs[sort_idx]\n",
    "    caps    = caps[sort_idx]\n",
    "    img_ids = [img_ids[i] for i in sort_idx.tolist()]\n",
