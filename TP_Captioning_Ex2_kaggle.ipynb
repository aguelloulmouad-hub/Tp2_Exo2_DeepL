    "    'Val PPL'                    : [f'{ppl_basic:.1f}', f'{ppl_att:.1f}'],\n",
    "    'Nb Params (M)'              : [f'{(params_enc_basic+params_dec_basic)/1e6:.1f}',\n",
    "                                    f'{(params_enc_att+params_dec_att)/1e6:.1f}'],\n",
    "    'Train / epoch (s)'          : [f'{train_epoch_basic:.1f}', f'{train_epoch_att:.1f}'],\n",
    "    'Inférence greedy (ms)'      : [f'{inf_basic:.1f}', f'{inf_att:.1f}']\n",
