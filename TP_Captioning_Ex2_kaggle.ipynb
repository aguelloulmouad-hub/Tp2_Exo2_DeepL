    "---\n",
    "## Partie 2 — Encodeur CNN et Décodeur LSTM\n",
    "\n",
    "### Q3 — ImageEncoder + CaptionDecoder : forward pass et vérification des dimensions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── ImageEncoder ─────────────────────────────────────────────────────────\n",
    "class ImageEncoder(nn.Module):\n",
    "    \"\"\"Encodeur CNN basé sur ResNet50 pré-entraîné.\n",
    "    Retourne un vecteur global de taille embed_size.\n",
    "    \"\"\"\n",
    "    def __init__(self, embed_size=256, fine_tune=False):\n",
    "        super().__init__()\n",
    "        resnet   = resnet50(weights=ResNet50_Weights.IMAGENET1K_V2)\n",
    "        # Supprimer la tête de classification (avgpool + fc)\n",
    "        modules  = list(resnet.children())[:-2]     # sortie : (B, 2048, 7, 7)\n",
    "        self.resnet        = nn.Sequential(*modules)\n",
    "        self.adaptive_pool = nn.AdaptiveAvgPool2d((1, 1))\n",
    "        self.fc            = nn.Linear(2048, embed_size)\n",
    "        self.bn            = nn.BatchNorm1d(embed_size)\n",
    "\n",
    "        # Geler l'encodeur sauf les 2 derniers blocs (layer3, layer4)\n",
    "        for param in self.resnet[:6].parameters():\n",
    "            param.requires_grad = fine_tune\n",
    "        for param in self.resnet[6:].parameters():\n",
    "            param.requires_grad = True   # layer3 et layer4 toujours entraînés\n",
    "\n",
    "    def forward(self, images):\n",
    "        features = self.resnet(images)            # (B, 2048, 7, 7)\n",
    "        features = self.adaptive_pool(features)   # (B, 2048, 1, 1)\n",
    "        features = features.squeeze(-1).squeeze(-1)  # (B, 2048)\n",
    "        features = self.bn(self.fc(features))     # (B, embed_size)\n",
    "        return features\n",
    "\n",
    "\n",
    "# ── CaptionDecoder ────────────────────────────────────────────────────────\n",
    "class CaptionDecoder(nn.Module):\n",
    "    \"\"\"Décodeur LSTM pour la génération de captions.\n",
    "    Le vecteur image est injecté comme premier token (teacher forcing).\n",
    "    \"\"\"\n",
    "    def __init__(self, embed_size, hidden_size, vocab_size,\n",
    "                 num_layers=2, dropout=0.5):\n",
    "        super().__init__()\n",
    "        self.embed = nn.Embedding(vocab_size, embed_size, padding_idx=0)\n",
    "        self.lstm  = nn.LSTM(embed_size, hidden_size, num_layers,\n",
    "                             batch_first=True, dropout=dropout if num_layers > 1 else 0)\n",
    "        self.fc      = nn.Linear(hidden_size, vocab_size)\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "\n",
    "    def forward(self, features, captions, lengths):\n",
    "        \"\"\"\n",
    "        features : (B, embed_size)    — sortie de l'encodeur\n",
    "        captions : (B, max_len)       — captions numérisées (avec <SOS> et <EOS>)\n",
    "        lengths  : (B,)               — longueurs réelles (pour pack_padded_sequence)\n",
    "        \"\"\"\n",
    "        # Embedding des captions (on retire le dernier token = <EOS> en entrée)\n",
    "        embeddings = self.dropout(self.embed(captions[:, :-1]))   # (B, T-1, embed_size)\n",
    "        # Concaténer le vecteur image comme premier token\n",
    "        inputs = torch.cat([features.unsqueeze(1), embeddings], dim=1)  # (B, T, embed_size)\n",
    "        # Clamp lengths pour éviter les dépassements\n",
    "        lengths_cpu = lengths.cpu().clamp(max=inputs.size(1))\n",
    "        packed  = nn.utils.rnn.pack_padded_sequence(\n",
    "            inputs, lengths_cpu, batch_first=True, enforce_sorted=True\n",
    "        )\n",
    "        hiddens, _ = self.lstm(packed)\n",
    "        hiddens, _ = nn.utils.rnn.pad_packed_sequence(hiddens, batch_first=True)  # (B, T, H)\n",
    "        out = self.fc(hiddens)  # (B, T, vocab_size)\n",
    "        return out\n",
    "\n",
    "    def generate_greedy(self, features, vocab, max_len=50, device='cpu'):\n",
    "        \"\"\"Génération greedy (token le plus probable à chaque étape).\"\"\"\n",
    "        self.eval()\n",
    "        with torch.no_grad():\n",
    "            inp = features.unsqueeze(1)          # (1, 1, embed_size)\n",
    "            h, c = None, None\n",
    "            if h is None:\n",
    "                out, (h, c) = self.lstm(inp)\n",
    "            word_idx = torch.tensor([[vocab.stoi['<SOS>']]], device=device)\n",
    "            result   = []\n",
    "            for _ in range(max_len):\n",
    "                emb = self.dropout(self.embed(word_idx))   # (1,1,embed)\n",
    "                out, (h, c) = self.lstm(emb, (h, c))\n",
    "                pred = self.fc(out.squeeze(1)).argmax(dim=-1)  # (1,)\n",
    "                idx  = pred.item()\n",
    "                if idx == vocab.stoi['<EOS>']:\n",
    "                    break\n",
    "                if idx not in (vocab.stoi['<PAD>'], vocab.stoi['<SOS>']):\n",
    "                    result.append(vocab.itos.get(idx, '<UNK>'))\n",
    "                word_idx = pred.unsqueeze(0)\n",
    "        return ' '.join(result)\n",
    "\n",
    "\n",
    "# ── Q3 : Instanciation et vérification forward ────────────────────────────\n",
    "VOCAB_SIZE = len(vocab)\n",
    "encoder = ImageEncoder(embed_size=EMBED_SIZE, fine_tune=False).to(device)\n",
    "decoder = CaptionDecoder(\n",
    "    embed_size=EMBED_SIZE,\n",
    "    hidden_size=HIDDEN_SIZE,\n",
    "    vocab_size=VOCAB_SIZE,\n",
    "    num_layers=NUM_LAYERS,\n",
    "    dropout=DROPOUT\n",
    ").to(device)\n",
    "\n",
    "# Batch fictif pour vérification\n",
    "B_test   = 4\n",
    "x_test   = torch.randn(B_test, 3, IMG_SIZE, IMG_SIZE).to(device)\n",
    "cap_test = torch.randint(4, VOCAB_SIZE, (B_test, MAX_LEN)).to(device)\n",
    "cap_test[:, 0] = vocab.stoi['<SOS>']\n",
    "cap_test[:, -1] = vocab.stoi['<EOS>']\n",
    "len_test = torch.tensor([MAX_LEN] * B_test)\n",
    "\n",
    "encoder.eval(); decoder.eval()\n",
    "with torch.no_grad():\n",
    "    feats_test = encoder(x_test)\n",
    "    out_test   = decoder(feats_test, cap_test, len_test)\n",
    "\n",
    "print(\"\\n📐 Vérification des dimensions — Forward pass :\")\n",
    "print(f\"   Entrée image        : {list(x_test.shape)}\")\n",
    "print(f\"   Sortie encodeur     : {list(feats_test.shape)}  → (B, embed_size={EMBED_SIZE})\")\n",
    "print(f\"   Caption input       : {list(cap_test.shape)}   → (B, max_len={MAX_LEN})\")\n",
    "print(f\"   Sortie décodeur     : {list(out_test.shape)} → (B, T, vocab_size={VOCAB_SIZE})\")\n",
    "print(f\"   Taille du vocabulaire : {VOCAB_SIZE}\")\n",
    "print(f\"   Paramètres encodeur : {sum(p.numel() for p in encoder.parameters()):,}\")\n",
    "print(f\"   Paramètres décodeur : {sum(p.numel() for p in decoder.parameters()):,}\")\n",
    "encoder.train(); decoder.train()"
   ]
  },
