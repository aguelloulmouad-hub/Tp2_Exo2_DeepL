   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "smooth = SmoothingFunction().method1\n",
    "\n",
    "# ── Q8 : METEOR / CIDEr (officiel si pycocoevalcap est disponible) ────────\n",
    "def _tokens_to_sentence(tokens):\n",
    "    return ' '.join(tokens).strip()\n",
    "\n",
    "def _fallback_meteor(refs_list, hyp_tokens):\n",
    "    \"\"\"Approximation légère du METEOR si pycocoevalcap n'est pas disponible.\"\"\"\n",
    "    hyp_set  = Counter(hyp_tokens)\n",
    "    ref_set  = Counter([w for ref in refs_list for w in ref])\n",
    "    matches  = sum(min(hyp_set[w], ref_set[w]) for w in hyp_set)\n",
    "    if not matches:\n",
    "        return 0.0\n",
    "    p = matches / max(len(hyp_tokens), 1)\n",
    "    r = matches / max(len(ref_set), 1)\n",
    "    return 0.0 if (p + r) == 0 else 2 * p * r / (p + r)\n",
    "\n",
    "def _fallback_cider(refs_list, hyp_tokens):\n",
    "    \"\"\"Approximation légère du CIDEr si pycocoevalcap n'est pas disponible.\"\"\"\n",
    "    all_words = [w for ref in refs_list for w in ref]\n",
    "    ref_freq  = Counter(all_words)\n",
    "    hyp_freq  = Counter(hyp_tokens)\n",
    "    score     = 0.0\n",
    "    for w in hyp_freq:\n",
    "        if w in ref_freq:\n",
    "            tf  = hyp_freq[w] / max(len(hyp_tokens), 1)\n",
    "            ref_tf = ref_freq[w] / max(len(all_words), 1)\n",
    "            score += tf * ref_tf\n",
    "    return score * 10\n",
    "\n",
    "def compute_caption_metrics(refs_list, hyps_list):\n",
    "    \"\"\"\n",
    "    refs_list : [[ref1_tokens, ref2_tokens, ...], ...]\n",
    "    hyps_list : [hyp_tokens, ...]\n",
    "    Retourne BLEU-1, BLEU-4, METEOR, CIDEr.\n",
    "    \"\"\"\n",
    "    if HAS_COCO_CAPTION_METRICS:\n",
    "        gts = {i: [_tokens_to_sentence(r) for r in refs] for i, refs in enumerate(refs_list)}\n",
    "        res = {i: [_tokens_to_sentence(hyp)] for i, hyp in enumerate(hyps_list)}\n",
    "\n",
    "        bleu_scorer = Bleu(4)\n",
    "        bleu_scores, _ = bleu_scorer.compute_score(gts, res)  # [BLEU-1 ... BLEU-4]\n",
    "        meteor_score, _ = Meteor().compute_score(gts, res)\n",
    "        cider_score, _ = Cider().compute_score(gts, res)\n",
    "\n",
    "        return {\n",
    "            'BLEU-1': float(bleu_scores[0]),\n",
    "            'BLEU-4': float(bleu_scores[3]),\n",
    "            'METEOR': float(meteor_score),\n",
    "            'CIDEr': float(cider_score),\n",
    "        }\n",
    "\n",
    "    # Fallback : scores cohérents pour un notebook offline\n",
    "    bleu1 = corpus_bleu(refs_list, hyps_list, weights=(1,0,0,0), smoothing_function=smooth)\n",
    "    bleu4 = corpus_bleu(refs_list, hyps_list, weights=(0.25,0.25,0.25,0.25), smoothing_function=smooth)\n",
    "    meteor = np.mean([_fallback_meteor(r, h) for r, h in zip(refs_list, hyps_list)])\n",
    "    cider  = np.mean([_fallback_cider(r, h) for r, h in zip(refs_list, hyps_list)])\n",
    "    return {'BLEU-1': float(bleu1), 'BLEU-4': float(bleu4), 'METEOR': float(meteor), 'CIDEr': float(cider)}\n",
    "\n",
    "metrics_basic = compute_caption_metrics(refs_bleu_greedy, hyps_bleu_greedy)\n",
    "metrics_att   = compute_caption_metrics(refs_att, hyps_att)\n",
    "\n",
    "print(\"✅ Métriques COCO calculées pour CNN-LSTM et CNN-LSTM+Attention.\")\n",
    "print(f\"   CNN-LSTM          : BLEU-1={metrics_basic['BLEU-1']:.4f} | BLEU-4={metrics_basic['BLEU-4']:.4f} | \"\n",
    "      f\"METEOR={metrics_basic['METEOR']:.4f} | CIDEr={metrics_basic['CIDEr']:.4f}\")\n",
    "print(f\"   CNN-LSTM+Attention: BLEU-1={metrics_att['BLEU-1']:.4f} | BLEU-4={metrics_att['BLEU-4']:.4f} | \"\n",
    "      f\"METEOR={metrics_att['METEOR']:.4f} | CIDEr={metrics_att['CIDEr']:.4f}\")"
   ]
