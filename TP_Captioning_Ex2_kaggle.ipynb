   "source": [
    "# ── Fonctions d'entraînement et de validation ─────────────────────────────\n",
    "def train_epoch(enc, dec, loader, criterion, opt_enc, opt_dec, device):\n",
    "    enc.train(); dec.train()\n",
    "    total_loss = 0.0\n",
    "    for imgs, caps, lengths, _ in tqdm(loader, desc='Train', leave=False):\n",
    "        imgs = imgs.to(device, non_blocking=True)\n",
    "        caps = caps.to(device, non_blocking=True)\n",
    "\n",
    "        features = enc(imgs)                         # (B, embed_size)\n",
    "        outputs  = dec(features, caps, lengths)      # (B, T, vocab)\n",
    "\n",
    "        # Cibles = captions décalées d'un rang (on prédit le mot suivant)\n",
    "        targets = caps[:, 1:]                        # (B, T)\n",
    "        T = min(outputs.size(1), targets.size(1))\n",
    "        loss = criterion(\n",
    "            outputs[:, :T].reshape(-1, VOCAB_SIZE),\n",
    "            targets[:, :T].reshape(-1)\n",
    "        )\n",
    "        opt_enc.zero_grad(); opt_dec.zero_grad()\n",
    "        loss.backward()\n",
    "        nn.utils.clip_grad_norm_(dec.parameters(), max_norm=5.0)\n",
    "        nn.utils.clip_grad_norm_(enc.parameters(), max_norm=5.0)\n",
    "        opt_enc.step(); opt_dec.step()\n",
    "        total_loss += loss.item()\n",
    "    return total_loss / len(loader)\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def eval_epoch(enc, dec, loader, criterion, device):\n",
    "    enc.eval(); dec.eval()\n",
    "    total_loss = 0.0\n",
    "    for imgs, caps, lengths, _ in tqdm(loader, desc='Val  ', leave=False):\n",
    "        imgs = imgs.to(device, non_blocking=True)\n",
    "        caps = caps.to(device, non_blocking=True)\n",
    "        features = enc(imgs)\n",
    "        outputs  = dec(features, caps, lengths)\n",
    "        targets  = caps[:, 1:]\n",
    "        T = min(outputs.size(1), targets.size(1))\n",
    "        loss = criterion(\n",
    "            outputs[:, :T].reshape(-1, VOCAB_SIZE),\n",
    "            targets[:, :T].reshape(-1)\n",
    "        )\n",
    "        total_loss += loss.item()\n",
    "    return total_loss / len(loader)\n",
    "\n",
    "\n",
    "# ── Critère, optimiseurs, scheduler ──────────────────────────────────────\n",
    "criterion = nn.CrossEntropyLoss(ignore_index=0)  # ignore_index=0 → <PAD>\n",
    "\n",
    "# Optimiseurs séparés pour l'encodeur et le décodeur\n",
    "opt_enc = torch.optim.Adam(filter(lambda p: p.requires_grad, encoder.parameters()),\n",
    "                            lr=1e-4, weight_decay=1e-4)\n",
    "opt_dec = torch.optim.Adam(decoder.parameters(), lr=LR, weight_decay=1e-4)\n",
    "\n",
    "scheduler_enc = torch.optim.lr_scheduler.ReduceLROnPlateau(opt_enc, patience=3, factor=0.5)\n",
    "scheduler_dec = torch.optim.lr_scheduler.ReduceLROnPlateau(opt_dec, patience=3, factor=0.5)\n",
    "\n",
    "# Multi-GPU wrapping (DataParallel)\n",
    "if num_gpus > 1:\n",
    "    enc_parallel = nn.DataParallel(encoder)\n",
    "else:\n",
    "    enc_parallel = encoder\n",
    "\n",
    "print(f\"Critère      : CrossEntropyLoss (ignore_index=0 pour <PAD>)\")\n",
    "print(f\"Optimiseurs  : Adam | enc lr=1e-4 | dec lr={LR}\")\n",
    "print(f\"Scheduler    : ReduceLROnPlateau (patience=3, factor=0.5)\")\n",
    "print(f\"DataParallel : {num_gpus > 1} ({num_gpus} GPU)\")"
   ]
  },
