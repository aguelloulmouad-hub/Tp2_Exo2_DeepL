    "refs_att  = []\n",
    "hyps_att  = []\n",
    "\n",
    "for item in tqdm(eval_samples, desc='BLEU-ATT eval'):\n",
    "    img_t = tf_val(Image.open(item['img_path']).convert('RGB'))\n",
    "    cap   = generate_att_greedy(enc_att, dec_att, img_t, vocab, MAX_LEN, device)\n",
    "    refs  = [Vocabulary.tokenize(r) for r in val_img_to_refs.get(item['image_id'], [''])]\n",
    "    refs_att.append(refs)\n",
    "    hyps_att.append(Vocabulary.tokenize(cap))\n",
    "\n",
    "bleu1_att = corpus_bleu(refs_att, hyps_att, weights=(1,0,0,0), smoothing_function=smooth)\n",
    "bleu4_att = corpus_bleu(refs_att, hyps_att, weights=(0.25,0.25,0.25,0.25), smoothing_function=smooth)\n",
    "\n",
    "print(f\"\\n📈 CNN-LSTM+Attention — BLEU-1: {bleu1_att:.4f} | BLEU-4: {bleu4_att:.4f}\")"
   ]
