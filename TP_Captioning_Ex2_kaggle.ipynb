    "### Q7 — Visualisation des cartes d'attention"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Charger le meilleur modèle attention ──────────────────────────────────\n",
    "ckpt_att = torch.load('best_captioning_attention.pth', map_location=device)\n",
    "enc_att.load_state_dict(ckpt_att['encoder'])\n",
    "dec_att.load_state_dict(ckpt_att['decoder'])\n",
    "enc_att.eval(); dec_att.eval()\n",
    "print(\"✅ Meilleur checkpoint attention chargé.\")\n",
    "\n",
    "\n",
    "# ── Génération avec attention (greedy + alphas) ───────────────────────────\n",
    "@torch.no_grad()\n",
    "def generate_with_attention(enc, dec, image_tensor, vocab,\n",
    "                             max_len=50, device='cpu'):\n",
    "    enc.eval(); dec.eval()\n",
    "    img     = image_tensor.unsqueeze(0).to(device)\n",
    "    enc_out = enc(img)                              # (1, 49, 2048)\n",
    "\n",
    "    h, c    = dec.init_hidden_state(enc_out)        # (1, H), (1, H)\n",
    "    word    = torch.tensor([vocab.stoi['<SOS>']], device=device)  # (1,)\n",
    "\n",
    "    words_generated = []\n",
    "    alphas_list     = []\n",
    "\n",
    "    for _ in range(max_len):\n",
    "        embed   = dec.dropout(dec.embed(word.unsqueeze(0)))  # (1, 1, E)\n",
    "        context, alpha = dec.attention(enc_out, h)           # (1, enc_dim), (1, 49)\n",
    "        lstm_in = torch.cat([embed.squeeze(1), context], dim=1)  # (1, E+enc_dim)\n",
    "        h, c    = dec.lstm_cell(lstm_in, (h, c))\n",
    "        pred    = dec.fc(dec.dropout(h))             # (1, V)\n",
    "        word    = pred.argmax(dim=-1)                # (1,)\n",
    "        idx     = word.item()\n",
    "\n",
    "        alphas_list.append(alpha.squeeze(0).cpu().numpy())\n",
    "\n",
    "        if idx == vocab.stoi['<EOS>']:\n",
    "            break\n",
    "        if idx not in (vocab.stoi['<PAD>'], vocab.stoi['<SOS>']):\n",
    "            words_generated.append((vocab.itos.get(idx, '<UNK>'), alpha.squeeze(0).cpu().numpy()))\n",
    "\n",
    "    return words_generated, alphas_list\n",
    "\n",
    "\n",
    "# ── Q7 : Visualisation pour 4 images de test ─────────────────────────────\n",
    "test_samples_att = []\n",
    "seen_ids_att = set()\n",
    "for item in ds_val.data:\n",
    "    if item['image_id'] not in seen_ids_att:\n",
    "        seen_ids_att.add(item['image_id'])\n",
    "        test_samples_att.append(item)\n",
    "    if len(test_samples_att) == 4:\n",
    "        break\n",
    "\n",
    "for img_idx, item in enumerate(test_samples_att):\n",
    "    pil_img = Image.open(item['img_path']).convert('RGB')\n",
    "    img_t   = tf_val(pil_img)\n",
    "\n",
    "    words_and_alphas, _ = generate_with_attention(enc_att, dec_att, img_t, vocab, MAX_LEN, device)\n",
    "\n",
    "    if not words_and_alphas:\n",
    "        print(f\"Image {img_idx+1} : aucun mot généré.\")\n",
    "        continue\n",
    "\n",
    "    # Afficher les 8 premiers mots avec leur carte d'attention\n",
    "    n_words = min(8, len(words_and_alphas))\n",
    "    fig, axes = plt.subplots(2, n_words, figsize=(n_words * 2.5, 5))\n",
    "    if n_words == 1:\n",
    "        axes = axes.reshape(2, 1)\n",
    "\n",
    "    fig.suptitle(\n",
    "        f\"Q7 — Cartes d'attention — Image {img_idx+1}\\n\"\n",
    "        f\"Génération : {' '.join([w for w, _ in words_and_alphas])}\",\n",
    "        fontsize=11, fontweight='bold'\n",
    "    )\n",
    "\n",
    "    # Image originale redimensionnée\n",
    "    orig_np = np.array(pil_img.resize((224, 224)))\n",
    "\n",
    "    for t in range(n_words):\n",
    "        word_t, alpha_t = words_and_alphas[t]\n",
    "\n",
    "        # Image originale (ligne 0)\n",
    "        axes[0, t].imshow(orig_np)\n",
    "        axes[0, t].set_title(f'\"{word_t}\"', fontsize=9)\n",
    "        axes[0, t].axis('off')\n",
    "\n",
    "        # Carte d'attention superposée (ligne 1)\n",
    "        # Redimensionner alpha (49,) → (7,7) → (224,224)\n",
    "        att_map = alpha_t.reshape(7, 7)\n",
    "        att_map = np.array(Image.fromarray(\n",
    "            (att_map * 255).astype(np.uint8)\n",
    "        ).resize((224, 224), Image.BILINEAR)) / 255.0\n",
    "\n",
    "        axes[1, t].imshow(orig_np)\n",
    "        axes[1, t].imshow(att_map, cmap='jet', alpha=0.45)\n",
    "        axes[1, t].set_title(f'α max={alpha_t.max():.2f}', fontsize=8)\n",
    "        axes[1, t].axis('off')\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.savefig(f'q7_attention_map_img{img_idx+1}.png', dpi=130, bbox_inches='tight')\n",
    "    plt.show()\n",
    "\n",
    "print(\"\\n📝 Commentaire : Les régions colorées (chaud = rouge/jaune) indiquent\")\n",
    "print(\"   les zones d'image auxquelles le modèle 'prête attention' lors de la\")\n",
    "print(\"   génération de chaque mot. On s'attend à ce que des mots comme 'dog',\")\n",
    "print(\"   'person', 'car' focalisent sur les objets correspondants.\")"
   ]
