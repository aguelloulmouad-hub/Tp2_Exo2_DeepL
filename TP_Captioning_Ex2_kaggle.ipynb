   "source": [
    "# ── Charger le meilleur modèle ────────────────────────────────────────────\n",
    "ckpt = torch.load('best_captioning_basic.pth', map_location=device)\n",
    "encoder.load_state_dict(ckpt['encoder'])\n",
    "decoder.load_state_dict(ckpt['decoder'])\n",
    "encoder.eval(); decoder.eval()\n",
    "print(\"✅ Meilleur checkpoint chargé.\")\n",
    "\n",
    "\n",
    "# ── Génération Greedy ─────────────────────────────────────────────────────\n",
    "@torch.no_grad()\n",
    "def generate_greedy(enc, dec, image_tensor, vocab, max_len=50, device='cpu'):\n",
    "    enc.eval(); dec.eval()\n",
    "    img = image_tensor.unsqueeze(0).to(device)\n",
    "    feat = enc(img)                               # (1, embed_size)\n",
    "    # Initialiser le LSTM avec le vecteur image\n",
    "    inp = feat.unsqueeze(1)                       # (1, 1, embed_size)\n",
    "    out, (h, c) = dec.lstm(inp)\n",
    "    word_idx = torch.tensor([[vocab.stoi['<SOS>']]], device=device)\n",
    "    result   = []\n",
    "    for _ in range(max_len):\n",
    "        emb = dec.dropout(dec.embed(word_idx))    # (1, 1, embed_size)\n",
    "        out, (h, c) = dec.lstm(emb, (h, c))\n",
    "        pred = dec.fc(out.squeeze(1)).argmax(dim=-1)  # (1,)\n",
    "        idx  = pred.item()\n",
    "        if idx == vocab.stoi['<EOS>']:\n",
    "            break\n",
    "        if idx not in (vocab.stoi['<PAD>'], vocab.stoi['<SOS>']):\n",
    "            result.append(vocab.itos.get(idx, '<UNK>'))\n",
    "        word_idx = pred.unsqueeze(0)\n",
    "    return ' '.join(result)\n",
    "\n",
    "\n",
    "# ── Génération Beam Search ────────────────────────────────────────────────\n",
    "@torch.no_grad()\n",
    "def beam_search_caption(enc, dec, image_tensor, vocab,\n",
    "                         beam_size=3, max_len=50, device='cpu'):\n",
    "    enc.eval(); dec.eval()\n",
    "    img  = image_tensor.unsqueeze(0).to(device)\n",
    "    feat = enc(img)                               # (1, embed_size)\n",
    "\n",
    "    # Initialisation du LSTM avec le vecteur image\n",
    "    inp       = feat.unsqueeze(1)                 # (1, 1, embed_size)\n",
    "    _, (h0, c0) = dec.lstm(inp)\n",
    "\n",
    "    # Beams : (score cumulé, séquence, hidden state)\n",
    "    beams     = [(0.0, [vocab.stoi['<SOS>']], (h0, c0))]\n",
    "    completed = []\n",
    "\n",
    "    for _ in range(max_len):\n",
    "        new_beams = []\n",
    "        for score, seq, hidden in beams:\n",
    "            last_word = torch.tensor([[seq[-1]]], device=device)\n",
    "            embed     = dec.dropout(dec.embed(last_word))     # (1,1,E)\n",
    "            out, (h, c) = dec.lstm(embed, hidden)\n",
    "            logprobs  = F.log_softmax(dec.fc(out.squeeze(1)), dim=-1)  # (1, V)\n",
    "            topk_s, topk_i = logprobs.topk(beam_size)\n",
    "            for s, idx in zip(topk_s[0], topk_i[0]):\n",
    "                new_seq   = seq + [idx.item()]\n",
    "                new_score = score + s.item()\n",
    "                new_h     = (h.clone(), c.clone())\n",
    "                if idx.item() == vocab.stoi['<EOS>']:\n",
    "                    completed.append((new_score / len(new_seq), new_seq))\n",
    "                else:\n",
    "                    new_beams.append((new_score, new_seq, new_h))\n",
    "        # Conserver les beam_size meilleurs beams (par score normalisé)\n",
    "        beams = sorted(new_beams, key=lambda x: x[0] / len(x[1]), reverse=True)[:beam_size]\n",
    "        if not beams:\n",
    "            break\n",
    "\n",
    "    # Sélectionner le meilleur beam complété\n",
    "    if not completed:\n",
    "        completed = [(beams[0][0] / len(beams[0][1]), beams[0][1])]\n",
    "    best_score, best_seq = max(completed, key=lambda x: x[0])\n",
    "\n",
    "    # Décoder (ignorer <SOS> et <EOS>)\n",
    "    words = [vocab.itos.get(i, '<UNK>') for i in best_seq[1:]\n",
    "             if i not in (vocab.stoi['<EOS>'], vocab.stoi['<PAD>'])]\n",
    "    return ' '.join(words)\n",
    "\n",
    "\n",
    "print(\"✅ Fonctions de génération définies (Greedy & Beam Search beam_size=3).\")"
   ]
