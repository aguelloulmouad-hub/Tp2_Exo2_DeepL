    "# ── Téléchargement des images COCO (batch parallèle) ─────────────────────\n",
    "import urllib.request\n",
    "from concurrent.futures import ThreadPoolExecutor, as_completed\n",
    "\n",
    "COCO_BASE_URL_TRAIN = 'http://images.cocodataset.org/train2017/'\n",
    "COCO_BASE_URL_VAL   = 'http://images.cocodataset.org/val2017/'\n",
    "\n",
    "def download_image(args):\n",
    "    img_info, base_url, img_dir = args\n",
    "    fname = img_info['file_name']\n",
    "    dest  = os.path.join(img_dir, fname)\n",
    "    if not os.path.exists(dest):\n",
    "        try:\n",
    "            urllib.request.urlretrieve(base_url + fname, dest)\n",
    "        except Exception as e:\n",
    "            return fname, False, str(e)\n",
    "    return fname, True, ''\n",
    "\n",
    "def batch_download(ids_set, images_info, base_url, img_dir, label, max_workers=32):\n",
    "    tasks  = [(images_info[iid], base_url, img_dir) for iid in ids_set if iid in images_info]\n",
    "    ok, ko = 0, 0\n",
    "    with ThreadPoolExecutor(max_workers=max_workers) as ex:\n",
    "        futs = {ex.submit(download_image, t): t for t in tasks}\n",
    "        for fut in tqdm(as_completed(futs), total=len(tasks), desc=f'Téléchargement {label}'):\n",
    "            _, success, _ = fut.result()\n",
    "            if success: ok += 1\n",
    "            else:       ko += 1\n",
    "    print(f\"{label}: {ok} images téléchargées, {ko} erreurs.\")\n",
    "\n",
    "batch_download(selected_train_ids, train_images_info, COCO_BASE_URL_TRAIN, COCO_IMG_DIR_TRAIN, 'train')\n",
    "batch_download(selected_val_ids,   val_images_info,   COCO_BASE_URL_VAL,   COCO_IMG_DIR_VAL,   'val')"
   ]
  },
